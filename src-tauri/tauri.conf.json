{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trading Buddy BETA v0.2",
  "version": "0.2.0",
  "identifier": "com.tradingbuddy.desktop",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "corepack pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Companion Home — Trading Buddy BETA v0.2",
        "url": "index.html?view=main",
        "width": 1100,
        "height": 740,
        "minWidth": 760,
        "minHeight": 520,
        "center": true,
        "visible": false
      },
      {
        "label": "buddy",
        "title": "Trading Buddy Buddy — BETA v0.2",
        "url": "index.html?view=buddy",
        "width": 140,
        "height": 140,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "bubble",
        "title": "Trading Buddy Bubble",
        "url": "index.html?view=bubble",
        "width": 300,
        "height": 220,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
